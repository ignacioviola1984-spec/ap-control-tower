# Plantilla NO secreta de configuracion de persistencia (Fase 1).
# Copiar a config/persistence.env (gitignoreado) y ajustar. NUNCA commitear
# credenciales reales. Sin AP_DATABASE_URL la app corre igual que hoy (sin base).

# --- Variables del contenedor Postgres de desarrollo (docker-compose.dev.yml) ---
POSTGRES_USER=ap
POSTGRES_PASSWORD=ap_dev_local
POSTGRES_DB=ap_control_tower
POSTGRES_PORT=5432

# --- URL que consume la app y Alembic (formato SQLAlchemy) ---
# Postgres local (docker-compose.dev.yml):
AP_DATABASE_URL=postgresql+psycopg://ap:ap_dev_local@localhost:5432/ap_control_tower
# Alternativa portable sin infra (dev/tests):
# AP_DATABASE_URL=sqlite+pysqlite:///./ap_local.db

# Poner en 1 para ver el SQL emitido (diagnostico; nunca en produccion).
AP_DB_ECHO=0
